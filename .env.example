# StudyMap environment variables.
# Everything except sign-in and personal pins works WITHOUT any of these.
# Copy this file to .env.local and fill in the values to enable Google sign-in.

# Supabase project (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth is configured inside Supabase (Authentication -> Providers -> Google).
# Add your Google Cloud OAuth client ID and secret there, then set the redirect URL
# to: <your-site-url>/auth/callback

# Umami analytics (optional, production only). Privacy-friendly and cookieless.
# Create a site at https://cloud.umami.is, then copy its Website ID here.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Only set this if you self-host Umami. Defaults to the Umami Cloud script.
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
